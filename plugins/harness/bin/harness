#!/usr/bin/env node
/**
 * bin/harness — Claude Code Harness CLI
 *
 * Subcommands:
 *   harness init                  Create harness.config.json interactively
 *   harness check                 Verify plugin install integrity
 *   harness doctor                Diagnose local environment
 *   harness rules list            List active guardrail rules
 *   harness rules test <command>  Dry-run a bash command against R01-R13
 *   harness model resolve <agent> Print effective Codex model for <agent> (JSON)
 *   harness model check [--strict]  Flag deprecated models vs ~/.codex/models_cache.json
 *   harness migrate [--from PATH] Migrate legacy v2 state to the v3 JSON store
 *   harness --version
 */

import { existsSync, readFileSync, writeFileSync, statSync } from "node:fs";
import { dirname, join, resolve } from "node:path";
import { fileURLToPath } from "node:url";
import { homedir } from "node:os";

const __dirname = dirname(fileURLToPath(import.meta.url));

// Resolve the plugin root directory. Prefer the directory adjacent to `bin/`
// (standard install) and fall back to `CLAUDE_PLUGIN_ROOT` when the CLI is
// invoked inside a hook whose working tree points at a different install.
// Both `resolveCorePath()` and `cmdCheck()` must share this logic so that
// the integrity report and the core loader inspect the same tree.
function resolvePluginRoot() {
  const direct = resolve(__dirname, "..");
  if (existsSync(join(direct, "core", "dist", "index.js"))) return direct;
  const envRoot = process.env.CLAUDE_PLUGIN_ROOT;
  if (envRoot && existsSync(join(envRoot, "core", "dist", "index.js"))) {
    return envRoot;
  }
  return direct;
}

// Resolve the plugin's own core build. Works whether invoked via `bin/`
// (which is on PATH once the plugin is installed) or via a direct path.
function resolveCorePath() {
  const candidate = join(resolvePluginRoot(), "core", "dist", "index.js");
  return existsSync(candidate) ? candidate : null;
}

function printUsage() {
  process.stdout.write(
    [
      "harness — Claude Code Harness CLI",
      "",
      "Usage:",
      "  harness init                  Create harness.config.json (if missing)",
      "  harness check                 Verify the plugin is installed correctly",
      "  harness doctor                Diagnose local environment",
      "  harness rules list            List active guardrail rules",
      "  harness rules test <cmd>      Dry-run a bash command against R01-R13",
      "  harness model resolve <agent> Print effective Codex model for <agent>",
      "  harness model check [--strict]  Flag deprecated models vs models_cache.json",
      "  harness migrate [--from D]    Migrate legacy .claude/state to v3 JSON",
      "  harness --version",
      "",
    ].join("\n"),
  );
}

function readVersion() {
  const pkgPath = resolve(__dirname, "..", ".claude-plugin", "plugin.json");
  try {
    const raw = JSON.parse(readFileSync(pkgPath, "utf-8"));
    return raw.version ?? "0.0.0";
  } catch {
    return "unknown";
  }
}

// ------------------------------------------------------------
// Subcommands
// ------------------------------------------------------------

function cmdInit(cwd) {
  const out = resolve(cwd, "harness.config.json");
  if (existsSync(out)) {
    process.stderr.write(`harness init: ${out} already exists; leaving it untouched.\n`);
    return 0;
  }
  const starter = {
    projectName: "my-project",
    language: "en",
    protectedDirectories: [],
    protectedEnvVarNames: [
      "OPENAI_API_KEY",
      "ANTHROPIC_API_KEY",
      "AWS_ACCESS_KEY_ID",
      "AWS_SECRET_ACCESS_KEY",
      "GITHUB_TOKEN",
      "GOOGLE_API_KEY",
    ],
    protectedFileSuffixes: [".env"],
    codex: { enabled: false },
    workMode: { bypassRmRf: false, bypassGitPush: false },
    tampering: { severity: "approve" },
  };
  writeFileSync(out, JSON.stringify(starter, null, 2) + "\n", "utf-8");
  process.stdout.write(`harness init: wrote ${out}\n`);
  return 0;
}

function cmdCheck() {
  const checks = [];
  const corePath = resolveCorePath();
  checks.push(["core build", corePath !== null ? "OK" : "MISSING"]);

  // Use the same root as resolveCorePath so `CLAUDE_PLUGIN_ROOT` switches
  // (e.g. hook-invoked CLI) are honored by the integrity check.
  const pluginRoot = resolvePluginRoot();
  const expected = [
    [".claude-plugin/plugin.json", "manifest"],
    ["hooks/hooks.json", "hook registration"],
    ["scripts/hook-dispatcher.mjs", "dispatcher"],
    ["agents/worker.md", "worker agent"],
    ["agents/reviewer.md", "reviewer agent"],
    ["agents/scaffolder.md", "scaffolder agent"],
    ["agents/codex-sync.md", "codex-sync agent"],
    ["agents/coderabbit-mimic.md", "coderabbit-mimic agent"],
    ["agents/security-auditor.md", "security-auditor agent"],
    ["commands/harness-plan.md", "plan command"],
    ["commands/harness-work.md", "work command"],
    ["commands/harness-review.md", "review command"],
    ["commands/harness-release.md", "release command"],
    ["commands/harness-setup.md", "setup command"],
    ["commands/branch-merge.md", "branch-merge command"],
    ["commands/new-feature-branch.md", "new-feature-branch command"],
    ["commands/coderabbit-review.md", "coderabbit-review command"],
    ["commands/codex-team.md", "codex-team command"],
    ["commands/parallel-worktree.md", "parallel-worktree command"],
    ["commands/pseudo-coderabbit-loop.md", "pseudo-coderabbit-loop command"],
    ["commands/tdd-implement.md", "tdd-implement command"],
  ];
  for (const [rel, label] of expected) {
    const path = join(pluginRoot, rel);
    checks.push([label, existsSync(path) ? "OK" : `MISSING: ${rel}`]);
  }

  let ok = true;
  for (const [label, status] of checks) {
    process.stdout.write(`  ${label.padEnd(24)} ${status}\n`);
    if (status !== "OK") ok = false;
  }
  return ok ? 0 : 1;
}

async function cmdDoctor() {
  const out = [];
  out.push(`harness version:     ${readVersion()}`);
  out.push(`node version:        ${process.version}`);
  out.push(`platform:            ${process.platform}/${process.arch}`);
  out.push(`CLAUDE_PLUGIN_ROOT:  ${process.env.CLAUDE_PLUGIN_ROOT ?? "(unset)"}`);
  out.push(`CLAUDE_PROJECT_DIR:  ${process.env.CLAUDE_PROJECT_DIR ?? "(unset)"}`);
  out.push(`cwd:                 ${process.cwd()}`);
  const corePath = resolveCorePath();
  out.push(`core build:          ${corePath ?? "NOT FOUND"}`);
  if (corePath !== null) {
    try {
      const stat = statSync(corePath);
      out.push(`core build mtime:    ${stat.mtime.toISOString()}`);
    } catch {
      // ignore
    }
  }

  // Codex companion (optional — used by codex-sync / coderabbit-mimic agents).
  // `os.homedir()` handles Windows (USERPROFILE) + POSIX HOME + edge
  // cases where HOME is unset in container / CI environments. Falling
  // back to `process.env.HOME ?? ""` previously caused `path.join("", …)`
  // to resolve relative to cwd, producing false "codex not installed" /
  // false user-overlay readings on Windows.
  const home = homedir();
  const codexDir = join(home, ".claude", "plugins", "cache", "openai-codex", "codex");
  if (existsSync(codexDir)) {
    out.push(`codex plugin:        detected at ${codexDir}`);
  } else {
    // Hint uses a fully-qualified `claude plugin install` command so the user
    // can copy-paste from any directory; `install-project.sh` would be a
    // relative path that doesn't exist in the user's project root.
    out.push(`codex plugin:        not installed (optional — install with 'claude plugin install codex@openai-codex --scope project' to enable codex-sync / coderabbit-mimic)`);
  }

  // Project-local overrides / overlays.
  const projectDir = process.env.CLAUDE_PROJECT_DIR ?? process.cwd();
  const harnessConfigPath = join(projectDir, "harness.config.json");
  if (existsSync(harnessConfigPath)) {
    out.push(`harness.config.json: ${harnessConfigPath}`);
    try {
      const cfg = JSON.parse(readFileSync(harnessConfigPath, "utf-8"));
      const checklistPath = cfg?.security?.projectChecklistPath;
      if (typeof checklistPath === "string" && checklistPath.length > 0) {
        const resolvedChecklist = resolve(projectDir, checklistPath);
        if (existsSync(resolvedChecklist)) {
          out.push(`project security checklist: ${resolvedChecklist}`);
        } else {
          out.push(`project security checklist: MISSING (${checklistPath} from harness.config.json does not resolve)`);
        }
      }
      const plansFile = cfg?.work?.plansFile;
      if (typeof plansFile === "string" && plansFile.length > 0) {
        const plansPath = resolve(projectDir, plansFile);
        out.push(`plans file:          ${plansPath}${existsSync(plansPath) ? "" : " (missing)"}`);
      }
      const handoffFiles = Array.isArray(cfg?.work?.handoffFiles) ? cfg.work.handoffFiles : [];
      for (let i = 0; i < handoffFiles.length; i++) {
        const rel = handoffFiles[i];
        if (typeof rel !== "string") {
          // Warn so misconfigurations (null / number / object entries) stay
          // visible instead of being silently dropped from the report.
          out.push(
            `handoff file:        WARN entry [${i}] is not a string (got ${typeof rel}): ${JSON.stringify(rel)}`,
          );
          continue;
        }
        if (rel.length === 0) {
          out.push(`handoff file:        WARN entry [${i}] is an empty string`);
          continue;
        }
        const p = resolve(projectDir, rel);
        out.push(`handoff file:        ${p}${existsSync(p) ? "" : " (missing — optional)"}`);
      }
    } catch (err) {
      out.push(`harness.config.json: PARSE ERROR (${err instanceof Error ? err.message : String(err)})`);
    }
  } else {
    out.push(`harness.config.json: not found at ${harnessConfigPath} (run 'harness init' to create one)`);
  }

  // Project-local skill scaffold (harness plugin's project-local convention).
  const localSkillDir = join(projectDir, ".claude", "skills");
  if (existsSync(localSkillDir)) {
    out.push(`project skill dir:   ${localSkillDir}`);
  } else {
    out.push(`project skill dir:   none (optional — see CONTRIBUTING.md §5 test-bed policy)`);
  }

  // User-scope overlay (identifies plugin is running with user-level skills available).
  const userClaudeDir = join(home, ".claude");
  const userSkills = join(userClaudeDir, "skills");
  const userCommands = join(userClaudeDir, "commands");
  const userAgents = join(userClaudeDir, "agents");
  out.push(
    `user overlays:       skills=${existsSync(userSkills) ? "yes" : "no"}, commands=${existsSync(userCommands) ? "yes" : "no"}, agents=${existsSync(userAgents) ? "yes" : "no"}`,
  );

  process.stdout.write(out.join("\n") + "\n");
  return 0;
}

async function cmdRulesList() {
  const corePath = resolveCorePath();
  if (corePath === null) {
    process.stderr.write("harness rules list: core build not found. Run `npm run build`.\n");
    return 1;
  }
  const rulesPath = corePath.replace("index.js", "guardrails/rules.js");
  const rulesMod = await import(`file://${rulesPath.replace(/\\/g, "/")}`);
  for (const rule of rulesMod.GUARD_RULES) {
    process.stdout.write(`  ${rule.id.padEnd(36)} tool=${rule.toolPattern}\n`);
  }
  return 0;
}

async function cmdRulesTest(command) {
  if (!command) {
    process.stderr.write("usage: harness rules test <bash-command>\n");
    return 2;
  }
  const corePath = resolveCorePath();
  if (corePath === null) {
    process.stderr.write("harness rules test: core build not found.\n");
    return 1;
  }
  const preToolPath = corePath.replace("index.js", "guardrails/pre-tool.js");
  const mod = await import(`file://${preToolPath.replace(/\\/g, "/")}`);
  const result = mod.evaluatePreTool({
    tool_name: "Bash",
    tool_input: { command },
    cwd: process.cwd(),
  });
  process.stdout.write(JSON.stringify(result, null, 2) + "\n");
  return 0;
}

// ------------------------------------------------------------
// harness model resolve / harness model check
// ------------------------------------------------------------

async function loadResolverModule() {
  const corePath = resolveCorePath();
  if (corePath === null) return null;
  const resolverPath = corePath.replace(
    "index.js",
    "models/resolver.js",
  );
  if (!existsSync(resolverPath)) return null;
  return await import(`file://${resolverPath.replace(/\\/g, "/")}`);
}

async function loadProjectModelsConfig() {
  const corePath = resolveCorePath();
  if (corePath === null) return undefined;
  const configPath = corePath.replace("index.js", "config.js");
  const mod = await import(`file://${configPath.replace(/\\/g, "/")}`);
  const projectDir = process.env.CLAUDE_PROJECT_DIR ?? process.cwd();
  const cfg = mod.loadConfigSafe
    ? mod.loadConfigSafe(projectDir)
    : mod.loadConfig(projectDir);
  return cfg?.models;
}

function loadCodexModelsCache() {
  const home = homedir();
  const cachePath = join(home, ".codex", "models_cache.json");
  if (!existsSync(cachePath)) return null;
  try {
    const raw = JSON.parse(readFileSync(cachePath, "utf-8"));
    const configPath = join(home, ".codex", "config.toml");
    const migrations = {};
    if (existsSync(configPath)) {
      // Normalise CRLF / CR to LF before regex matching so Windows line
      // endings inside the user's config.toml do not leak stray `\r` into
      // migration keys / values. The section is small (kv pairs) so a
      // dedicated TOML parser would be overkill.
      const toml = readFileSync(configPath, "utf-8").replace(/\r\n?/g, "\n");
      // Parse the [notice.model_migrations] block without a TOML lib; the
      // section is small (kv pairs) and we only need string → string.
      const blockMatch = toml.match(
        /\[notice\.model_migrations\]\s*([\s\S]*?)(?=\n\[|$)/,
      );
      if (blockMatch) {
        const body = blockMatch[1];
        const lineRe = /"([^"]+)"\s*=\s*"([^"]+)"/g;
        let m;
        while ((m = lineRe.exec(body)) !== null) {
          migrations[m[1]] = m[2];
        }
      }
    }
    return {
      models: raw.models,
      upgrade: raw.upgrade,
      migrations,
    };
  } catch (err) {
    process.stderr.write(
      `harness model check: failed to read models cache (${
        err instanceof Error ? err.message : String(err)
      })\n`,
    );
    return null;
  }
}

async function cmdModelResolve(agent) {
  if (!agent) {
    process.stderr.write("usage: harness model resolve <agent>\n");
    return 2;
  }
  const mod = await loadResolverModule();
  if (!mod) {
    process.stderr.write(
      "harness model resolve: core build not found. Run `npm run build`.\n",
    );
    return 1;
  }
  const config = await loadProjectModelsConfig();
  const resolution = mod.resolveModel(config, agent);
  process.stdout.write(JSON.stringify(resolution, null, 2) + "\n");
  return 0;
}

async function cmdModelCheck(strict) {
  const mod = await loadResolverModule();
  if (!mod) {
    process.stderr.write(
      "harness model check: core build not found. Run `npm run build`.\n",
    );
    return 1;
  }
  const config = await loadProjectModelsConfig();
  const cache = loadCodexModelsCache();
  const report = mod.checkModels(config, cache);
  process.stdout.write(JSON.stringify(report, null, 2) + "\n");
  if (strict && report.hits.length > 0) return 1;
  return 0;
}

async function cmdMigrate(fromDir) {
  const corePath = resolveCorePath();
  if (corePath === null) {
    process.stderr.write("harness migrate: core build not found.\n");
    return 1;
  }
  const migPath = corePath.replace("index.js", "state/migration.js");
  const mod = await import(`file://${migPath.replace(/\\/g, "/")}`);
  const target = fromDir ? resolve(fromDir) : process.cwd();
  const result = mod.migrate(target);
  process.stdout.write(JSON.stringify(result, null, 2) + "\n");
  return result.errors.length > 0 ? 1 : 0;
}

// ------------------------------------------------------------
// Entry
// ------------------------------------------------------------

async function main() {
  const [sub, ...rest] = process.argv.slice(2);
  if (!sub || sub === "--help" || sub === "-h") {
    printUsage();
    return 0;
  }
  if (sub === "--version" || sub === "-v") {
    process.stdout.write(`${readVersion()}\n`);
    return 0;
  }
  switch (sub) {
    case "init":
      return cmdInit(process.cwd());
    case "check":
      return cmdCheck();
    case "doctor":
      return await cmdDoctor();
    case "rules": {
      const [action, ...args] = rest;
      if (action === "list") return await cmdRulesList();
      if (action === "test") return await cmdRulesTest(args.join(" "));
      process.stderr.write("usage: harness rules list | test <cmd>\n");
      return 2;
    }
    case "model": {
      const [action, ...args] = rest;
      if (action === "resolve") return await cmdModelResolve(args[0]);
      if (action === "check") return await cmdModelCheck(args.includes("--strict"));
      process.stderr.write(
        "usage: harness model resolve <agent> | check [--strict]\n",
      );
      return 2;
    }
    case "migrate": {
      const flagIdx = rest.indexOf("--from");
      const fromDir = flagIdx >= 0 ? rest[flagIdx + 1] : undefined;
      return await cmdMigrate(fromDir);
    }
    default:
      process.stderr.write(`harness: unknown subcommand '${sub}'\n`);
      printUsage();
      return 2;
  }
}

main().then(
  (code) => process.exit(code ?? 0),
  (err) => {
    process.stderr.write(`harness: ${err instanceof Error ? err.message : String(err)}\n`);
    process.exit(1);
  },
);
