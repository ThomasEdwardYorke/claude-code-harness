{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/ThomasEdwardYorke/claude-code-harness/main/plugins/harness/schemas/harness.config.schema.json",
  "title": "HarnessConfig",
  "description": "Per-project configuration for Claude Code Harness. Lives at <projectRoot>/harness.config.json.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional $schema URL (enables editor completion)."
    },
    "projectName": {
      "type": "string",
      "description": "Human-readable project name shown in messages."
    },
    "language": {
      "type": "string",
      "enum": ["en", "ja"],
      "default": "en"
    },
    "protectedDirectories": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Directory names that R10 refuses to delete via rm/rmdir/unlink. Empty array disables R10."
    },
    "protectedEnvVarNames": {
      "type": "array",
      "items": { "type": "string" },
      "default": [
        "OPENAI_API_KEY",
        "ANTHROPIC_API_KEY",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "GITHUB_TOKEN",
        "GOOGLE_API_KEY"
      ],
      "description": "Environment-variable names R11 blocks in Bash commands. Empty array disables R11."
    },
    "protectedFileSuffixes": {
      "type": "array",
      "items": { "type": "string" },
      "default": [".env"],
      "description": "File suffixes whose direct read (cat/head/tail/less/more/open/echo) R13 blocks."
    },
    "codex": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "pluginRoot": { "type": "string" }
      }
    },
    "workMode": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bypassRmRf": { "type": "boolean", "default": false },
        "bypassGitPush": { "type": "boolean", "default": false }
      }
    },
    "tampering": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["approve", "ask", "deny"],
          "default": "approve"
        }
      }
    },
    "work": {
      "type": "object",
      "additionalProperties": false,
      "description": "Settings consumed by /harness-work, /tdd-implement, /parallel-worktree, and core hooks (stop / subagent-stop / pre-compact / task-lifecycle).",
      "properties": {
        "plansFile": {
          "type": "string",
          "default": "Plans.md",
          "description": "Relative path to the project's task / plan file. Consumed by pre-compact and task-lifecycle hooks to read assignment tables before compaction."
        },
        "assignmentSectionMarkers": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["担当表", "Assignment", "In Progress"],
          "description": "Section header keywords used to locate the assignment table inside the plans file. Supports ja/en projects. First-match wins."
        },
        "handoffFiles": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Project-specific session-handoff file paths that /harness-work and /parallel-worktree update when closing a session. Existence-optional (if a listed path is missing, the hook skips it silently)."
        },
        "changeLogFile": {
          "type": "string",
          "description": "Optional relative path to a project-local change log consumed by /harness-plan sync. If unset, sync skips change-log scanning."
        },
        "maxParallel": { "type": "integer", "minimum": 1, "maximum": 16, "default": 4 },
        "labelPriority": {
          "type": "array",
          "items": { "type": "string" }
        },
        "criticalLabels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "testCommand": { "type": "string" },
        "qualityGates": {
          "type": "object",
          "additionalProperties": false,
          "description": "Per-project override of harness quality gates. Consumed by stop.ts to emit reminders.",
          "properties": {
            "enforceTddImplement": { "type": "boolean", "default": true },
            "enforcePseudoCoderabbit": { "type": "boolean", "default": true },
            "enforceRealCoderabbit": { "type": "boolean", "default": true },
            "enforceCodexSecondOpinion": { "type": "boolean", "default": true }
          }
        },
        "failFast": { "type": "boolean", "default": true }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "description": "Settings consumed by security-auditor agent. Lets projects supply their own stack-specific security checklist without modifying plugin core.",
      "properties": {
        "projectChecklistPath": {
          "type": "string",
          "description": "Relative path to a project-local security checklist (e.g. `./AGENTS.md`, `./docs/security.md`, or a SKILL.md reference). security-auditor agent loads this file as addendum when present; otherwise runs the stack-neutral generic checklist only."
        },
        "enabledChecks": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "api-key-leak",
              "injection",
              "file-permissions",
              "dependencies",
              "project-specific"
            ]
          },
          "default": ["api-key-leak", "injection", "file-permissions", "dependencies"],
          "description": "Enabled security check categories. `project-specific` is effective only when `projectChecklistPath` is set."
        }
      }
    },
    "worktree": {
      "type": "object",
      "additionalProperties": false,
      "description": "Settings consumed by /parallel-worktree and parallel-sessions.sh.",
      "properties": {
        "enabled": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "enum": ["auto"] }
          ],
          "default": "auto"
        },
        "maxParallel": { "type": "integer", "minimum": 1, "maximum": 16, "default": 4 },
        "parentDir": { "type": "string", "default": ".." },
        "prefix": { "type": "string" },
        "defaultBaseBranch": { "type": "string" }
      }
    },
    "tddEnforce": {
      "type": "object",
      "additionalProperties": false,
      "description": "Settings consumed by /tdd-implement and /pseudo-coderabbit-loop.",
      "properties": {
        "alwaysRequireRedTest": { "type": "boolean", "default": true },
        "allowSkipOnDocsTasks": { "type": "boolean", "default": true },
        "pseudoCoderabbitProfile": {
          "type": "string",
          "enum": ["chill", "assertive", "strict"],
          "default": "chill",
          "description": "CodeRabbit 公式 profile は chill/assertive のみ。strict は harness-local 拡張。"
        },
        "maxCodexReviewRetries": { "type": "integer", "minimum": 0, "default": 3 }
      }
    },
    "codeRabbit": {
      "type": "object",
      "additionalProperties": false,
      "description": "Settings consumed by /coderabbit-review and /pseudo-coderabbit-loop.",
      "properties": {
        "botLogin": { "type": "string", "default": "coderabbitai" },
        "ratelimitCheckWindowMinutes": { "type": "integer", "minimum": 1, "default": 15 },
        "approvedStateAsClear": { "type": "boolean", "default": true },
        "maxPseudoLoopIterations": { "type": "integer", "minimum": 1, "default": 5 },
        "proBucketSize": { "type": "integer", "minimum": 1, "default": 5 },
        "proBucketWindowMinutes": { "type": "integer", "minimum": 1, "default": 60 }
      }
    }
  }
}
