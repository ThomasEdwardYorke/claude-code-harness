{
  "name": "claude-code-harness",
  "version": "0.3.2",
  "private": true,
  "description": "Portable guardrail and agent harness for Claude Code",
  "workspaces": ["plugins/harness/core"],
  "scripts": {
    "build": "npm run build --workspace=plugins/harness/core",
    "test": "npm test --workspace=plugins/harness/core",
    "test:coverage": "npm run test:coverage --workspace=plugins/harness/core",
    "typecheck": "npm run typecheck --workspace=plugins/harness/core",
    "smoke": "node tests/e2e/smoke.test.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
